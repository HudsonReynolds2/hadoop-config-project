<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<configuration>

  <!-- Metastore backing database: Postgres -->
  <property>
    <n>javax.jdo.option.ConnectionURL</n>
    <value>jdbc:postgresql://postgres-metastore:5432/metastore</value>
  </property>
  <property>
    <n>javax.jdo.option.ConnectionDriverName</n>
    <value>org.postgresql.Driver</value>
  </property>
  <property>
    <n>javax.jdo.option.ConnectionUserName</n>
    <value>hive</value>
  </property>
  <property>
    <n>javax.jdo.option.ConnectionPassword</n>
    <value>hive</value>
  </property>

  <!-- Warehouse lives on HDFS — MUTATED: wrong namenode host -->
  <property>
    <n>hive.metastore.warehouse.dir</n>
    <value>hdfs://wronghost:8020/user/hive/warehouse</value>
  </property>

  <!-- Metastore service -->
  <property>
    <n>hive.metastore.uris</n>
    <value>thrift://hive-metastore:9083</value>
  </property>

  <property>
    <n>datanucleus.schema.autoCreateAll</n>
    <value>false</value>
  </property>
  <property>
    <n>hive.metastore.schema.verification</n>
    <value>true</value>
  </property>

  <property>
    <n>hive.server2.thrift.port</n>
    <value>10000</value>
  </property>
  <property>
    <n>hive.server2.thrift.bind.host</n>
    <value>0.0.0.0</value>
  </property>
  <property>
    <n>hive.server2.webui.host</n>
    <value>0.0.0.0</value>
  </property>
  <property>
    <n>hive.server2.webui.port</n>
    <value>10002</value>
  </property>

  <property>
    <n>hive.server2.authentication</n>
    <value>NONE</value>
  </property>
  <property>
    <n>hive.server2.enable.doAs</n>
    <value>false</value>
  </property>

  <property>
    <n>fs.defaultFS</n>
    <value>hdfs://namenode:8020</value>
  </property>
</configuration>
