# Kept intentionally minimal. The canonical config lives in ./conf/*.xml which
# are bind-mounted into /opt/hadoop/etc/hadoop/. These env vars are redundant
# for services that mount the conf dir, but harmless; the config-checker tool
# can later detect and flag this intentional dual-source as a propagation case.

# Core — MUTATED: disagrees with core-site.xml's hdfs://namenode:8020
CORE-SITE.XML_fs.defaultFS=hdfs://wronghost:8020

# HDFS
HDFS-SITE.XML_dfs.namenode.rpc-address=namenode:8020
HDFS-SITE.XML_dfs.replication=1
HDFS-SITE.XML_dfs.namenode.name.dir=/hadoop/dfs/name
HDFS-SITE.XML_dfs.datanode.data.dir=/hadoop/dfs/data

# MapReduce
MAPRED-SITE.XML_mapreduce.framework.name=yarn
MAPRED-SITE.XML_mapreduce.application.classpath=/opt/hadoop/share/hadoop/mapreduce/*:/opt/hadoop/share/hadoop/mapreduce/lib/*

# YARN
YARN-SITE.XML_yarn.resourcemanager.hostname=resourcemanager
YARN-SITE.XML_yarn.nodemanager.aux-services=mapreduce_shuffle
YARN-SITE.XML_yarn.nodemanager.aux-services.mapreduce.shuffle.class=org.apache.hadoop.mapred.ShuffleHandler
YARN-SITE.XML_yarn.nodemanager.vmem-check-enabled=false
YARN-SITE.XML_yarn.nodemanager.resource.memory-mb=4096
YARN-SITE.XML_yarn.scheduler.maximum-allocation-mb=2048